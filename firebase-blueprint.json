{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A 3D printed product for sale.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" }
      },
      "required": ["name", "price", "imageUrl", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerEmail": { "type": "string" },
        "mbWayPhone": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "shippingMethod": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["mbWayPhone", "items", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Collection of products available in the shop."
    },
    "orders": {
      "schema": "Order",
      "description": "Collection of customer orders."
    }
  }
}
