rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email.toLower() == "jose.festas@gmail.com");
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Validate string length
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // Validate URL format (basic)
    function isValidUrl(url) {
      return url is string &&
        (url.matches("^https://.*") || url.matches("^http://.*") || url.matches("^data:image/.*"));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidProduct(data) {
      // Basic validation to ensure required fields exist and have correct types
      return data.name is string && 
             data.price is number && 
             data.imageUrl is string && 
             data.category is string;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Products Collection
    match /products/{productId} {
      // Anyone can read products to browse the shop
      allow read, list: if true;
      
      // Only admin can create, update, or delete products
      allow create, update, delete: if isAdmin();
    }

    // Test Collection (for connection test)
    match /test/{docId} {
      allow read: if true;
    }

    // Users Collection
    match /users/{userId} {
      // Users can only read and write their own profile data
      allow read, write: if isOwner(userId);
    }
  }
}
