rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "jose.festas@gmail.com" && request.auth.token.email_verified == true);
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Validate string length
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // Validate URL format (basic)
    function isValidUrl(url) {
      return url is string &&
        (url.matches("^https://.*") || url.matches("^http://.*") || url.matches("^data:image/.*"));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'imageUrl', 'category']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             isValidUrl(data.imageUrl) &&
             data.category is string && data.category.size() > 0 && data.category.size() < 50 &&
             (!('description' in data) || (data.description is string && data.description.size() < 2000)) &&
             (!('rating' in data) || (data.rating is number && data.rating >= 0 && data.rating <= 5)) &&
             (!('reviewCount' in data) || (data.reviewCount is number && data.reviewCount >= 0));
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Products Collection
    match /products/{productId} {
      // Anyone can read products to browse the shop
      allow read, list: if true;
      
      // Only admin can create, update, or delete products
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    // Test Collection (for connection test)
    match /test/{docId} {
      allow read: if true;
    }

    // Users Collection
    match /users/{userId} {
      // Users can only read and write their own profile data
      allow read, write: if isOwner(userId);
    }
  }
}
